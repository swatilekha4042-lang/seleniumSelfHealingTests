			font-weight: bold;
			text-decoration: underline;
		}

		a.blinkingText {
			float: right;
			margin-top: 12px;
			font-weight: bold;
			padding: 10px;
			background: #27b35f;
			font-size: 20px;
			color: #fff !important;
			animation: blink 1s linear infinite;
			text-decoration: underline;
			cursor: pointer;
		}

		@keyframes blink {
